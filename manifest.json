{
  "manifest_version": 3,
  "name": "Flight Grid Extender",
  "version": "1.1.0",
  "description": "Expand the Google Flights price calendar into a 30x30 departure-by-return price matrix. Unofficial; not affiliated with Google.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/travel/flights*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.google.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "flight-grid-extender@asadtariq",
      "strict_min_version": "109.0"
    }
  }
}
